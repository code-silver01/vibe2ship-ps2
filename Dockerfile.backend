FROM node:20-alpine

WORKDIR /app

# SQLite needs build tools
RUN apk add --no-cache python3 make g++ 

# Copy package files
COPY package.json ./

# Install dependencies
RUN npm install

# Copy source
COPY . .

# Ensure data directory exists for SQLite
RUN mkdir -p data

EXPOSE 3001

# Start server
CMD ["npm", "start"]
